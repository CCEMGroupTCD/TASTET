# Ignore everything inside use_cases by default
examples/**

# But keep use_cases folders visible
!examples/
!examples/*/

# Keep only clean public example files inside each use case
!examples/*/config.py
!examples/*/run.py
!examples/*/prepare.py
!use_cases/*/*.sdf
!use_cases/*/*.traj