# Python junk
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# macOS / Windows junk
.DS_Store
Thumbs.db

# Testing / cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Docs build output
docs/_build/

# Ignore everything inside examples by default
examples/**

# But keep the examples folder itself
!examples/

# Keep only the public example folders shown in the publication
!examples/nanoclusters/
!examples/rh_complex/

# Keep only clean public files inside those examples
!examples/nanoclusters/config.py
!examples/nanoclusters/run.py
!examples/nanoclusters/prepare.py

!examples/nanoclusters/input/
# Committed source of truth.  The per-run trajectories (input/run_*.traj)
# are derived from it by split_trajectory.py and stay untracked.
!examples/nanoclusters/input/all_runs.traj
!examples/nanoclusters/input/split_trajectory.py
!examples/nanoclusters/input/energies_selected.csv
!examples/nanoclusters/analysis/
!examples/nanoclusters/analysis/*.py

!examples/rh_complex/config.py
!examples/rh_complex/run.py
!examples/rh_complex/prepare.py
!examples/rh_complex/input/
!examples/rh_complex/input/*.sdf
!examples/rh_complex/input/energies_round1.csv
!examples/rh_complex/input/energies_round2.csv
!examples/rh_complex/analysis/
!examples/rh_complex/analysis/*.py
!examples/rh_complex/round2/
!examples/rh_complex/round2/*.py